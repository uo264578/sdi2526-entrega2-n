{% extends 'base.twig' %}

{% block title %}Lista de Empleados{% endblock %}

{% block content %}
    <div class="container mt-5">
        <h1 class="text-primary mb-4">Lista de Empleados</h1>

        {% if empleados is not empty %}
            <table class="table table-striped">
                <thead class="table-primary">
                <tr>
                    <th>DNI</th>
                    <th>Nombre</th>
                    <th>Apellidos</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                {% for empleado in empleados %}
                    <tr>
                        <td>{{ empleado.dni }}</td>
                        <td>{{ empleado.nombre }}</td>
                        <td>{{ empleado.apellidos }}</td>
                        <td>
                            <a class="btn btn-sm btn-warning" href="/admin/editar-empleado/{{ empleado._id }}">Editar</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <nav>
                <ul class="pagination">
                    {% for i in 1..totalPaginas %}
                        <li class="page-item {% if i == paginaActual %}active{% endif %}">
                            <a class="page-link" href="/admin/empleados?pagina={{ i }}">{{ i }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>

        {% else %}
            <div class="alert alert-warning" role="alert">
                No hay empleados registrados.
            </div>
        {% endif %}
    </div>
{% endblock %}
