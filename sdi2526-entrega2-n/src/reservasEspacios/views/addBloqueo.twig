{% extends 'base.twig' %}

{% block title %}Crear bloqueo{% endblock %}

{% block content %}
    <h1>Crear bloqueo de mantenimiento</h1>

    {% if errores %}
        <div class="alert alert-danger">
            <ul>
                {% for error in errores %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="/admin/bloqueos/add">
        <div class="form-group">
            <label>Espacio</label>
            <select class="form-control" name="espacioId">
                {% for espacio in espacios %}
                    <option value="{{ espacio._id }}" {% if bloqueo.espacioId == espacio._id %}selected{% endif %}>
                        {{ espacio.nombre }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="form-group">
            <label>Inicio</label>
            <input class="form-control" type="datetime-local" name="inicio" value="{{ bloqueo.inicio }}">
        </div>

        <div class="form-group">
            <label>Fin</label>
            <input class="form-control" type="datetime-local" name="fin" value="{{ bloqueo.fin }}">
        </div>

        <div class="form-group">
            <label>Motivo</label>
            <textarea class="form-control" name="motivo">{{ bloqueo.motivo }}</textarea>
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/admin/bloqueos" class="btn btn-secondary">Cancelar</a>
    </form>
{% endblock %}