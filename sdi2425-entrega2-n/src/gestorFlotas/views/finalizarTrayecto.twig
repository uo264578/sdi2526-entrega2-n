{% extends 'base.twig' %}

{% block title %}Finalizar Trayecto{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px;">
            <h2 class="text-center text-primary mb-4">Finalizar Trayecto</h2>

            {% if error %}
                <div class="alert alert-danger">
                    {{ error }}
                </div>
            {% endif %}

            {% if trayecto %}
                <form method="post" action="/trayectos/finalizar">
                    <div class="mb-3">
                        <label class="form-label">Matrícula</label>
                        <input type="text" class="form-control" value="{{ trayecto.matriculaVehiculo }}" readonly>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Odómetro Inicial</label>
                        <input type="text" class="form-control" value="{{ trayecto.odometroInicio }}" readonly>
                    </div>

                    <div class="mb-3">
                        <label for="odometroFin" class="form-label">Odómetro Final</label>
                        <input type="number" class="form-control" id="odometroFin" name="odometroFin" min="0" required>
                    </div>

                    <div class="mb-3">
                        <label for="observaciones" class="form-label">Observaciones (opcional)</label>
                        <textarea class="form-control" id="observaciones" name="observaciones" rows="3"></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Finalizar trayecto</button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
