{% extends 'base.twig' %}

{% block title %}Registrar Empleado{% endblock %}

{% block content %}
<div class="card shadow-lg p-4 mx-auto" style="max-width: 500px;">
    <h2 class="text-center text-primary mb-4">Registrar nuevo empleado</h2>

    {% if errores %}
        <div class="alert alert-danger">
            <ul class="mb-0">
            {% for error in errores %}
                <li>{{ error }}</li>
            {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if mensajeExito %}
        <div class="alert alert-success">
            {{ mensajeExito }}
        </div>
    {% endif %}

    <form method="post" action="/admin/registrar-empleado">
        <div class="mb-3">
            <label for="dni" class="form-label">DNI</label>
            <input type="text" class="form-control" id="dni" name="dni" required value="{{ dni|default('') }}">
        </div>

        <div class="mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <input type="text" class="form-control" id="nombre" name="nombre" required value="{{ nombre|default('') }}">
        </div>

        <div class="mb-3">
            <label for="apellidos" class="form-label">Apellidos</label>
            <input type="text" class="form-control" id="apellidos" name="apellidos" required value="{{ apellidos|default('') }}">
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary">Registrar empleado</button>
        </div>
    </form>
</div>
{% endblock %}
