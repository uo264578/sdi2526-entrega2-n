{% extends 'base.twig' %}

{% block title %}Iniciar Nuevo Trayecto{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px;">
            <h2 class="text-center text-primary mb-4">Iniciar Trayecto</h2>

            {% if error %}
                <div class="alert alert-danger">
                    {{ error }}
                </div>
            {% endif %}

            <form method="post" action="/trayectos/iniciar">
                <div class="mb-3">
                    <label for="matricula" class="form-label">Vehículo</label>
                    <select class="form-select" id="matricula" name="matricula" required>
                        <option value="">Seleccione un vehículo</option>
                        {% for vehiculo in vehiculos %}
                            <option value="{{ vehiculo.matricula }}">{{ vehiculo.matricula }} - {{ vehiculo.marca }} {{ vehiculo.modelo }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Iniciar trayecto</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
