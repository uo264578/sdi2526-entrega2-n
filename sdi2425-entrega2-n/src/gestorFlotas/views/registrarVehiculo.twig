{% extends 'base.twig' %}

{% block title %}Registrar Vehículo{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px;">
        <h2 class="text-center text-primary mb-4">Registrar nuevo vehículo</h2>

        {% if errores %}
            <div class="alert alert-danger">
                <ul class="mb-0">
                {% for error in errores %}
                    <li>{{ error }}</li>
                {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="/admin/registrar-vehiculo">
            <div class="mb-3">
                <label for="matricula" class="form-label">Matrícula</label>
                <input type="text" class="form-control" id="matricula" name="matricula" required value="{{ matricula|default('') }}">
            </div>

            <div class="mb-3">
                <label for="bastidor" class="form-label">Número de Bastidor</label>
                <input type="text" class="form-control" id="bastidor" name="bastidor" required value="{{ bastidor|default('') }}">
            </div>

            <div class="mb-3">
                <label for="marca" class="form-label">Marca</label>
                <input type="text" class="form-control" id="marca" name="marca" required value="{{ marca|default('') }}">
            </div>

            <div class="mb-3">
                <label for="modelo" class="form-label">Modelo</label>
                <input type="text" class="form-control" id="modelo" name="modelo" required value="{{ modelo|default('') }}">
            </div>

            <div class="mb-3">
                <label for="combustible" class="form-label">Tipo de Combustible</label>
                <select class="form-select" id="combustible" name="combustible" required>
                    <option value="">Seleccione</option>
                    <option {% if combustible == 'Gasolina' %}selected{% endif %}>Gasolina</option>
                    <option {% if combustible == 'Diesel' %}selected{% endif %}>Diesel</option>
                    <option {% if combustible == 'Microhíbrido' %}selected{% endif %}>Microhíbrido</option>
                    <option {% if combustible == 'Híbrido' %}selected{% endif %}>Híbrido</option>
                    <option {% if combustible == 'Eléctrico' %}selected{% endif %}>Eléctrico</option>
                    <option {% if combustible == 'GLP' %}selected{% endif %}>GLP</option>
                    <option {% if combustible == 'GNL' %}selected{% endif %}>GNL</option>
                </select>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Registrar vehículo</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
