{% extends 'base.twig' %}

{% block title %}Lista de Vehículos{% endblock %}

{% block content %}
    <div class="container mt-5">
        <h1 class="text-primary mb-4">Lista de Vehículos</h1>

        <form method="post" action="/admin/vehiculos/borrar">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                <tr>
                    <th></th>
                    <th>Matrícula</th>
                    <th>Bastidor</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Combustible</th>
                    <th>Kilometraje</th>
                    <th>Estado</th>
                </tr>
                </thead>
                <tbody>
                {% for vehiculo in vehiculos %}
                    <tr>
                        <td><input class="form-check-input" type="checkbox" name="vehiculos" value="{{ vehiculo._id }}"></td>
                        <td>{{ vehiculo.matricula }}</td>
                        <td>{{ vehiculo.bastidor }}</td>
                        <td>{{ vehiculo.marca }}</td>
                        <td>{{ vehiculo.modelo }}</td>
                        <td>{{ vehiculo.combustible }}</td>
                        <td>{{ vehiculo.kilometraje|default(0) }} km</td>
                        <td>{{ vehiculo.estado|default('LIBRE') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-danger btn-sm">Eliminar seleccionados</button>
            </div>

        </form>

        <nav class="mt-4">
            <ul class="pagination">
                {% for i in 1..totalPaginas %}
                    <li class="page-item {% if i == paginaActual %}active{% endif %}">
                        <a class="page-link" href="/admin/vehiculos?pagina={{ i }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>

    </div>
{% endblock %}
