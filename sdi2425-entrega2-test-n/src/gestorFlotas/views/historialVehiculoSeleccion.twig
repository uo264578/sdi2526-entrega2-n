{% extends 'base.twig' %}

{% block title %}Consultar Historial de Vehículo{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px;">
            <h2 class="text-center text-primary mb-4">Consultar Historial</h2>

            <form method="get" action="/trayectos/historial">
                <div class="mb-3">
                    <label for="matricula" class="form-label">Seleccione vehículo</label>
                    <select class="form-select" id="matricula" name="matricula" onchange="location = '/trayectos/historial/' + this.value;">
                        <option value="">Seleccione un vehículo...</option>
                        {% for vehiculo in vehiculos %}
                            <option value="{{ vehiculo.matricula }}">{{ vehiculo.matricula }} - {{ vehiculo.marca }} {{ vehiculo.modelo }}</option>
                        {% endfor %}
                    </select>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
