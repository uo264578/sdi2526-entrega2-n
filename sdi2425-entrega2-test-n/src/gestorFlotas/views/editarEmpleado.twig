{% extends 'base.twig' %}

{% block title %}Editar Empleado{% endblock %}

{% block content %}
    <div class="container mt-5">
        <h2 class="text-primary mb-4">Editar Empleado</h2>

        {% if errores %}
            <div class="alert alert-danger">
                <ul class="mb-0">
                    {% for error in errores %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" action="/admin/editar-empleado/{{ empleado._id }}">
            <div class="mb-3">
                <label for="dni" class="form-label">DNI</label>
                <input type="text" class="form-control" id="dni" name="dni" required value="{{ empleado.dni }}">
            </div>

            <div class="mb-3">
                <label for="nombre" class="form-label">Nombre</label>
                <input type="text" class="form-control" id="nombre" name="nombre" required value="{{ empleado.nombre }}">
            </div>

            <div class="mb-3">
                <label for="apellidos" class="form-label">Apellidos</label>
                <input type="text" class="form-control" id="apellidos" name="apellidos" required value="{{ empleado.apellidos }}">
            </div>

            <div class="mb-3">
                <label for="rol" class="form-label">Rol</label>
                <select class="form-select" name="rol" id="rol" required>
                    {% for rolDisponible in rolesDisponibles %}
                        <option {% if rolDisponible == empleado.rol %}selected{% endif %}>{{ rolDisponible }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
        </form>
    </div>
{% endblock %}
